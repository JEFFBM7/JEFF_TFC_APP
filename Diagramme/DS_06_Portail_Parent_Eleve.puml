@startuml DS_06_Portail_Parent_Eleve
title Diagramme de séquence — Portail Parent & Portail Élève

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam backgroundColor #FFFFFF
skinparam participant {
  BackgroundColor #F5EEF8
  BorderColor #8E44AD
}
skinparam sequence {
  ArrowColor #2C3E50
  LifeLineBorderColor #7F8C8D
  DividerBackgroundColor #F2F3F4
}

actor       Parent                      as PAR
actor       "Élève\n(≥ 7e)"             as ELV
participant "Frontend\n(Vue 3)"         as FE
participant "ParentPortalController"    as PPC
participant "StudentPortalController"   as SPC
participant "ParentDashboardService"    as PDS
participant "ReportCardService"         as RS
participant "AttendanceAlertService"    as AAS
participant "StudentTimelineService"    as STS
database    "Base de données"           as DB

== Dashboard Parent ==

PAR -> FE  : Se connecte (tél. comme identifiant)\net accède au tableau de bord
FE  -> PPC : GET /api/v1/parent-portal/dashboard

PPC -> DB  : ParentProfile WHERE user_id = auth()->id()
DB  --> PPC : Profil parent

PPC -> DB  : parent_student (pivot)\n→ Student WHERE is_current_school_year
DB  --> PPC : Liste des enfants

PPC -> PDS : build(request, students, user_id)

loop Pour chaque enfant
  PDS -> DB  : Term en cours (applicable au cycle de l'élève)
  DB  --> PDS : Terme actif

  PDS -> RS  : compute(student, currentTerm)
  RS  -> DB  : Grades + Evaluations (terme en cours)
  DB  --> RS : Notes
  RS  --> PDS : { overall_average, subjects }

  PDS -> AAS : check(student)
  AAS -> DB  : Attendance WHERE student_id + status=absent
  DB  --> AAS : Absences récentes
  AAS --> PDS : { triggered, consecutive, count_recent_30d }
end

PDS --> PPC : Payload résumé par enfant
PPC --> FE  : 200 { children: [{ student, average, alert, … }] }
FE  --> PAR : Tableau de bord avec résumé de chaque enfant

== Consultation du bulletin d'un enfant (Parent) ==

PAR -> FE  : Clique sur "Voir le bulletin" d'un enfant
FE  -> PPC : GET /api/v1/parent-portal/children/{student_id}/report-card/{term_id}
PPC -> PPC : authorizeChild(request, student)
note right
  Vérifie que l'élève appartient
  bien au parent connecté
end note
PPC -> RS  : compute(student, term)
RS  -> DB  : Évaluations + Notes + Appréciations
DB  --> RS : Données complètes
RS  --> PPC : Rapport calculé
PPC --> FE : 200 { student, term, subjects, period_averages, overall_average, appreciation }
FE  --> PAR : Bulletin affiché

== Consultation du bulletin PDF (Parent) ==

PAR -> FE  : Clique "Télécharger PDF"
FE  -> PPC : GET /api/v1/parent-portal/children/{student_id}/report-card/{term_id}/pdf
PPC -> PPC : authorizeChild + assertTermMatchesStudentCycle
PPC -> RS  : compute(student, term) + génération PDF
RS  --> PPC : PDF binaire
PPC --> FE  : Response (PDF attachment)
FE  --> PAR : Téléchargement du bulletin PDF

== Timeline de l'élève (Parent) ==

PAR -> FE  : Consulte l'historique de l'enfant
FE  -> PPC : GET /api/v1/parent-portal/children/{student_id}/timeline
PPC -> STS : getTimeline(student)
STS -> DB  : Grades (récentes) + Absences (récentes)\nregroupés par date
DB  --> STS : Événements
STS --> PPC : Timeline chronologique
PPC --> FE  : 200 { events: [{ date, type, description }] }
FE  --> PAR : Historique affiché

== Dashboard Élève (portail élève) ==

ELV -> FE  : Se connecte (matricule comme identifiant)
FE  -> SPC : GET /api/v1/student-portal/dashboard

SPC -> DB  : StudentProfileResolver::resolve(user)\n→ Student + classroom
DB  --> SPC : Profil élève

SPC -> DB  : SchoolYearContext::requestedOrCurrent()
DB  --> SPC : Année scolaire active

SPC -> SPC : resolveCurrentTermForStudent(schoolYear, student)
SPC -> RS  : compute(student, currentTerm)
RS  -> DB  : Évaluations + Notes
DB  --> RS : Notes
RS  --> SPC : { overall_average, subjects }

SPC -> AAS : check(student)
AAS -> DB  : Absences (30j)
DB  --> AAS : Données
AAS --> SPC : { triggered, count_recent_30d }

SPC --> FE : 200 { student, current_term, average, alert }
FE  --> ELV : Tableau de bord personnel

== Consultation de l'emploi du temps (Élève) ==

ELV -> FE  : Accède à "Mon emploi du temps"
FE  -> SPC : GET /api/v1/student-portal/timetable
SPC -> DB  : TimetableSlot WHERE classroom_id\nORDER BY day_of_week, start_time
DB  --> SPC : Créneaux horaires
SPC --> FE  : 200 TimetableSlotResource[]
FE  --> ELV : Emploi du temps affiché

@enduml
