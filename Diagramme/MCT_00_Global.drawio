  <diagram name="MCT Global" id="mct">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2080" pageHeight="966" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
                <mxCell id="title" value="MCT — Modèle Conceptuel des Traitements — EduConnect" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="0" y="0" width="2080" height="60" as="geometry" /></mxCell>
        <mxCell id="hdr0" value="Authentification" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#2980B9;strokeColor=#2980B9;fontColor=#FFFFFF;fontStyle=1;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="90" width="280" height="36" as="geometry" /></mxCell>
        <mxCell id="n1" value="Formulaire de connexion soumis (identifiant + mot de passe)" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#CA6F1E;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="152" width="280" height="60" as="geometry" /></mxCell>
        <mxCell id="en1" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" parent="1" source="hdr0" target="n1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n2" value="&lt;b&gt;Authentifier l'utilisateur&lt;/b&gt;&lt;br&gt;• Résoudre l'identifiant : email → users, matricule → students,&lt;br&gt;• n° enseignant → teachers, tél. → parent_profiles&lt;br&gt;• Vérifier le mot de passe et le statut est_actif" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2C3E50;fontSize=10.5;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="40" y="238" width="280" height="140" as="geometry" /></mxCell>
        <mxCell id="en2" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n3" value="OU" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F4ECF7;strokeColor=#7D3C98;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="162" y="404" width="36" height="28" as="geometry" /></mxCell>
        <mxCell id="en3" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n4" value="Identifiants invalides → rejet" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="448" width="280" height="46" as="geometry" /></mxCell>
        <mxCell id="en4" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;dashed=1;" edge="1" parent="1" source="n3" target="n4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n5" value="Compte désactivé → rejet" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="510" width="280" height="46" as="geometry" /></mxCell>
        <mxCell id="en5" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;dashed=1;" edge="1" parent="1" source="n3" target="n5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n6" value="Utilisateur authentifié → jeton créé" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="572" width="280" height="50" as="geometry" /></mxCell>
        <mxCell id="en6" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;dashed=1;" edge="1" parent="1" source="n3" target="n6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="hdr1" value="Inscription élève" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#27AE60;strokeColor=#27AE60;fontColor=#FFFFFF;fontStyle=1;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="380" y="90" width="280" height="36" as="geometry" /></mxCell>
        <mxCell id="n7" value="Formulaire d'inscription soumis par l'admin" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#CA6F1E;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="380" y="152" width="280" height="60" as="geometry" /></mxCell>
        <mxCell id="en7" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" parent="1" source="hdr1" target="n7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n8" value="&lt;b&gt;Enregistrer l'élève&lt;/b&gt;&lt;br&gt;• Vérifier les droits admin sur le cycle de la classe&lt;br&gt;• Générer un matricule unique&lt;br&gt;• Créer un compte portail si niveau ≥ 7e (secondaire)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2C3E50;fontSize=10.5;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="380" y="238" width="280" height="124" as="geometry" /></mxCell>
        <mxCell id="en8" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" parent="1" source="n7" target="n8"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n9" value="OU" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F4ECF7;strokeColor=#7D3C98;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="502" y="388" width="36" height="28" as="geometry" /></mxCell>
        <mxCell id="en9" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" parent="1" source="n8" target="n9"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n10" value="Élève inscrit, compte portail créé (≥ 7e)" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="380" y="432" width="280" height="50" as="geometry" /></mxCell>
        <mxCell id="en10" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;dashed=1;" edge="1" parent="1" source="n9" target="n10"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n11" value="Élève inscrit, sans compte portail (&lt; 7e)" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="380" y="498" width="280" height="50" as="geometry" /></mxCell>
        <mxCell id="en11" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;dashed=1;" edge="1" parent="1" source="n9" target="n11"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="hdr2" value="Évaluations &amp; Notes" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#F39C12;strokeColor=#F39C12;fontColor=#FFFFFF;fontStyle=1;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="720" y="90" width="280" height="36" as="geometry" /></mxCell>
        <mxCell id="n12" value="Évaluation définie (classe, matière, période)" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#CA6F1E;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="720" y="152" width="280" height="60" as="geometry" /></mxCell>
        <mxCell id="en12" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" parent="1" source="hdr2" target="n12"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n13" value="&lt;b&gt;Créer l'évaluation&lt;/b&gt;&lt;br&gt;• Rejeter si la période est clôturée&lt;br&gt;• Rejeter si l'enseignant n'est pas affecté à ce contexte" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2C3E50;fontSize=10.5;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="720" y="238" width="280" height="92" as="geometry" /></mxCell>
        <mxCell id="en13" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" parent="1" source="n12" target="n13"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n14" value="Évaluation créée" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="720" y="356" width="280" height="46" as="geometry" /></mxCell>
        <mxCell id="en14" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" parent="1" source="n13" target="n14"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n15" value="Notes saisies pour la classe" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#CA6F1E;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="720" y="428" width="280" height="60" as="geometry" /></mxCell>
