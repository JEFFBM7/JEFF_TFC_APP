        <mxCell id="n22" value="&lt;b&gt;Enregistrer les présences&lt;/b&gt;&lt;br&gt;• Un statut par élève / date / matière&lt;br&gt;• Calcule les absences consécutives et sur 30 jours" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2C3E50;fontSize=10.5;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="1060" y="238" width="280" height="92" as="geometry" /></mxCell>
