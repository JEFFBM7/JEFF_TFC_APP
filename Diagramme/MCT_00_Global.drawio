        <mxCell id="n27" value="&lt;b&gt;Justifier une absence&lt;/b&gt;" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2C3E50;fontSize=10.5;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="1060" y="624" width="280" height="50" as="geometry" /></mxCell>
