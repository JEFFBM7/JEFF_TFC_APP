        <mxCell id="n31" value="Bulletin calculé" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="1400" y="372" width="280" height="46" as="geometry" /></mxCell>
        <mxCell id="en31" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" parent="1" source="n30" target="n31"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n32" value="Export PDF demandé" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#CA6F1E;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="1400" y="444" width="280" height="60" as="geometry" /></mxCell>
