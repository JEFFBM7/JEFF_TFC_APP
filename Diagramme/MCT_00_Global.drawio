        <mxCell id="n33" value="&lt;b&gt;Générer le PDF&lt;/b&gt;&lt;br&gt;• Mise en forme selon le cycle : CTEB / primaire / secondaire" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2C3E50;fontSize=10.5;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="1400" y="530" width="280" height="76" as="geometry" /></mxCell>
