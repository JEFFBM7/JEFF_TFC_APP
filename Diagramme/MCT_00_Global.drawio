        <mxCell id="n28" value="Absence justifiée" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="1060" y="700" width="280" height="46" as="geometry" /></mxCell>
