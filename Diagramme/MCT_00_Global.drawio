        <mxCell id="n35" value="Message rédigé par un utilisateur" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#CA6F1E;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="1740" y="152" width="280" height="60" as="geometry" /></mxCell>
