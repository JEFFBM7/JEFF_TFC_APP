        <mxCell id="n20" value="Évaluation visible par les élèves et parents" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#D5F5E3;strokeColor=#1E8449;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="720" y="850" width="280" height="50" as="geometry" /></mxCell>
        <mxCell id="en20" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" parent="1" source="n19" target="n20"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="hdr3" value="Présences" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#E74C3C;strokeColor=#E74C3C;fontColor=#FFFFFF;fontStyle=1;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="1060" y="90" width="280" height="36" as="geometry" /></mxCell>
        <mxCell id="n21" value="Feuille d'appel soumise (classe, date)" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#CA6F1E;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="1060" y="152" width="280" height="60" as="geometry" /></mxCell>
