        <mxCell id="n36" value="&lt;b&gt;Envoyer le message&lt;/b&gt;&lt;br&gt;• Un expéditeur, un ou plusieurs destinataires (annonce)&lt;br&gt;• Lien vers le message parent si réponse à un fil" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2C3E50;fontSize=10.5;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="1740" y="238" width="280" height="108" as="geometry" /></mxCell>
