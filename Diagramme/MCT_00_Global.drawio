        <mxCell id="hdr4" value="Bulletins" style="rounded=1;arcSize=12;whiteSpace=wrap;html=1;fillColor=#2471A3;strokeColor=#2471A3;fontColor=#FFFFFF;fontStyle=1;fontSize=13;align=center;" vertex="1" parent="1"><mxGeometry x="1400" y="90" width="280" height="36" as="geometry" /></mxCell>
        <mxCell id="n29" value="Bulletin demandé (élève, trimestre)" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#FDEBD0;strokeColor=#CA6F1E;fontSize=10.5;align=center;" vertex="1" parent="1"><mxGeometry x="1400" y="152" width="280" height="60" as="geometry" /></mxCell>
        <mxCell id="en29" style="html=1;endArrow=block;endFill=1;strokeColor=#555555;" edge="1" parent="1" source="hdr4" target="n29"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="n30" value="&lt;b&gt;Calculer le bulletin&lt;/b&gt;&lt;br&gt;• Moyenne par matière : continu 40% + examen 60%&lt;br&gt;• Moyenne pondérée par période puis moyenne générale" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2C3E50;fontSize=10.5;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="1400" y="238" width="280" height="108" as="geometry" /></mxCell>
