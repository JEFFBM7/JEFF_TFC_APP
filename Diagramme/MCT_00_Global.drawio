        <mxCell id="n16" value="&lt;b&gt;Enregistrer les notes&lt;/b&gt;&lt;br&gt;• Une note par couple (élève, évaluation)&lt;br&gt;• Toute modification est tracée (audit)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#EBF5FB;strokeColor=#2C3E50;fontSize=10.5;align=left;spacingLeft=8;spacingTop=6;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="720" y="514" width="280" height="76" as="geometry" /></mxCell>
