@startuml MCD_02_Structure_Academique
title MCD — Structure académique

skinparam defaultFontName Arial
skinparam defaultFontSize 11
skinparam backgroundColor #FFFFFF

skinparam class {
  BackgroundColor<<entite>>      #D5F5E3
  BorderColor<<entite>>          #1E8449
  FontStyle<<entite>>            Bold
  BackgroundColor<<association>> #FEF9E7
  BorderColor<<association>>     #D4AC0D
  FontStyle<<association>>       Bold
  RoundCorner<<association>>     25
}

hide <<entite>>      circle
hide <<association>> circle

' ══════════════════════════════════════
'   ENTITÉS
' ══════════════════════════════════════

class "ANNEE_SCOLAIRE" <<entite>> {
  <u>id_annee</u>
  libelle
  date_debut
  date_fin
  est_courante
}

class "NIVEAU" <<entite>> {
  <u>id_niveau</u>
  nom
  abreviation
  cycle
  ordre
  a_options
}

class "OPTION" <<entite>> {
  <u>id_option</u>
  nom
  filiere
}

class "CLASSE_ANNUELLE" <<entite>> {
  <u>id_classe_annuelle</u>
  nom
  est_active
}

class "DIVISION" <<entite>> {
  <u>id_division</u>
  section
  est_active
}

class "MATIERE" <<entite>> {
  <u>id_matiere</u>
  nom
  code
  coefficient_defaut
}

class "TERME" <<entite>> {
  <u>id_terme</u>
  nom
  position
  type_terme
  cycle_applicable
}

class "PERIODE" <<entite>> {
  <u>id_periode</u>
  nom
  position
  date_debut
  date_fin
}

' ══════════════════════════════════════
'   ASSOCIATIONS
' ══════════════════════════════════════

class "PLANIFIE" <<association>>
class "NIVEAU_DE" <<association>>
class "OPTION_DE" <<association>>
class "COMPOSE_DE" <<association>>

class "PROGRAMME" <<association>> {
  coefficient
}

class "RYTHME" <<association>>
class "PERIODE_DE" <<association>>

' ══════════════════════════════════════
'   LIENS ET CARDINALITÉS
' ══════════════════════════════════════

' Classe annuelle ← Année scolaire + Niveau + Option
"ANNEE_SCOLAIRE"    "(1,N)"  --  "PLANIFIE"
"PLANIFIE"                   --  "(1,1)"  "CLASSE_ANNUELLE"

"NIVEAU"            "(1,N)"  --  "NIVEAU_DE"
"NIVEAU_DE"                  --  "(1,1)"  "CLASSE_ANNUELLE"

"OPTION"            "(0,N)"  --  "OPTION_DE"
"OPTION_DE"                  --  "(0,1)"  "CLASSE_ANNUELLE"

' Classe annuelle → Divisions
"CLASSE_ANNUELLE"   "(1,N)"  --  "COMPOSE_DE"
"COMPOSE_DE"                 --  "(1,1)"  "DIVISION"

' Division ↔ Matière (programme)
"DIVISION"  "(0,N)"  --  "PROGRAMME"
"PROGRAMME"          --  "(0,N)"  "MATIERE"

' Année → Termes → Périodes
"ANNEE_SCOLAIRE"    "(1,N)"  --  "RYTHME"
"RYTHME"                     --  "(1,1)"  "TERME"

"TERME"             "(1,N)"  --  "PERIODE_DE"
"PERIODE_DE"                 --  "(1,1)"  "PERIODE"

@enduml
