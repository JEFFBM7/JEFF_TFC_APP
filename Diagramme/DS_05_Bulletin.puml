@startuml DS_05_Bulletin
title Diagramme de séquence — Consultation et génération du bulletin

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam backgroundColor #FFFFFF
skinparam participant {
  BackgroundColor #EBF5FB
  BorderColor #2980B9
}
skinparam sequence {
  ArrowColor #2C3E50
  LifeLineBorderColor #7F8C8D
  DividerBackgroundColor #F2F3F4
}

actor       Admin                       as ADM
actor       Enseignant                  as ENS
participant "Frontend\n(Vue 3)"         as FE
participant "ReportCardController"      as RC
participant "ReportCardService"         as RS
participant "PrimaireBulletinFormatter" as PBF
participant "CtebBulletinFormatter"     as CBF
database    "Base de données"           as DB

== Calcul et affichage du bulletin (JSON) ==

ADM -> FE  : Sélectionne un élève et un trimestre/semestre
FE  -> RC  : GET /api/v1/report-cards/{student_id}/{term_id}

RC  -> DB  : AdminScopeContext::assertStudentAllowed(user, student)
RC  -> RS  : compute(student, term)

RS  -> DB  : Evaluation WHERE classroom_id + term_id (+ period_id)\nINNER JOIN grades WHERE student_id
DB  --> RS : Notes par évaluation et par matière

RS  -> RS  : Calcul par matière\n(moyenne continue 40% + examen 60%)
RS  -> RS  : Calcul par période\n(moyenne pondérée par coefficient)
RS  -> RS  : Calcul de la moyenne générale
RS  -> DB  : ReportCardAppreciation WHERE student_id + term_id
DB  --> RS : Appréciation (ou null)

RS  --> RC : { subjects, period_averages, overall_average, appreciation }
RC  --> FE : 200 { student, term, subjects, period_averages, overall_average, appreciation }
FE  --> ADM : Bulletin affiché à l'écran

== Classement de la division ==

ADM -> FE  : Consulte le classement de la division
FE  -> RC  : GET /api/v1/report-cards/ranking/{classroom_id}/{term_id}
RC  -> RS  : classRanking(classroom_id, term)

loop Pour chaque élève de la division
  RS  -> RS  : compute(student, term)
end

RS  -> RS  : Trie par moyenne_generale DESC
RS  --> RC : Liste ordonnée [{ rank, student_id, full_name, average }]
RC  --> FE : 200 { data: [ranking…] }
FE  --> ADM : Classement affiché

== Génération du bulletin PDF ==

ADM -> FE  : Clique "Télécharger le bulletin PDF"
FE  -> RC  : GET /api/v1/report-cards/{student_id}/{term_id}/pdf

RC  -> DB  : student->loadMissing('classroom.level')

alt Élève CTEB
  RC  -> CBF : isCtebStudent(student)
  CBF --> RC : true
  RC  -> CBF : buildAnnualPresentation(student, term)
  CBF -> DB  : Grades, Evaluations, Appreciation
  DB  --> CBF : Données annuelles formatées
  CBF --> RC : { bulletin_title, rows, percentage, appreciation }
  RC  -> RC  : Pdf::loadView('report_cards.cteb_pdf', …)\nsetPaper('a4', 'landscape')

else Élève primaire officiel
  RC  -> PBF : isOfficialPrimaireStudent(student)
  PBF --> RC : true
  RC  -> PBF : buildAnnualPresentation(student, term)
  PBF -> DB  : Grades, structure primaire, Appreciation
  DB  --> PBF : Données annuelles
  PBF --> RC : { bulletin_title, rows, percentage, form_code, grade_year }
  RC  -> RC  : Pdf::loadView('report_cards.primaire_debut_pdf', …)\nsetPaper('a4', 'landscape')

else Secondaire standard
  RC  -> RS  : compute(student, term)
  RS  -> DB  : Notes + Appréciations
  DB  --> RS : Données
  RS  --> RC : { subjects, period_averages, overall_average, appreciation }
  RC  -> RC  : Pdf::loadView('report_cards.pdf', …)\nsetPaper('a4')
end

RC  --> FE : Response (PDF binaire)\nContent-Disposition: attachment; filename="bulletin-…pdf"
FE  --> ADM : Téléchargement du PDF

== Saisie d'une appréciation (Enseignant) ==

ENS -> FE  : Saisit l'appréciation du trimestre pour un élève
FE  -> RC  : POST /api/v1/appreciations\n{ student_id, term_id, content }
RC  -> DB  : ReportCardAppreciation::updateOrCreate(\n  [student_id, term_id], [content, teacher_id]\n)
DB  --> RC : AppreciationBulletin
RC  --> FE : 200 { appreciation }
FE  --> ENS : Appréciation enregistrée

@enduml
