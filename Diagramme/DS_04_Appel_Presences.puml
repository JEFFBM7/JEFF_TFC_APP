@startuml DS_04_Appel_Presences
title Diagramme de séquence — Appel et gestion des présences

skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam backgroundColor #FFFFFF
skinparam participant {
  BackgroundColor #FDEDEC
  BorderColor #E74C3C
}
skinparam sequence {
  ArrowColor #2C3E50
  LifeLineBorderColor #7F8C8D
  DividerBackgroundColor #F2F3F4
}

actor       Enseignant              as ENS
actor       Admin                   as ADM
actor       Parent                  as PAR
participant "Frontend\n(Vue 3)"     as FE
participant "AttendanceController"  as AC
participant "AttendanceAlertService" as AAS
participant "AttendanceThresholdMailer" as ATM
database    "Base de données"       as DB

== Chargement de la feuille d'appel ==

ENS -> FE  : Sélectionne classe, date, matière (optionnel)
FE  -> AC  : GET /api/v1/attendances/roll-call\n?classroom_id=&date=&subject_id=

AC  -> DB  : Student WHERE classroom_id ORDER BY last_name
DB  --> AC : Liste des élèves

AC  -> DB  : Attendance WHERE classroom_id + date\n(+ subject_id si précisé)
DB  --> AC : Présences déjà enregistrées (ou vide)

AC  -> AC  : Fusionne : entrée existante sinon\nnouvelle Attendance(status=present)
AC  --> FE : 200 AttendanceResource[] (1 ligne / élève)
FE  --> ENS : Feuille d'appel affichée (statut par défaut = présent)

== Enregistrement de l'appel en lot ==

ENS -> FE  : Modifie les statuts (absent / en_retard)\net soumet
FE  -> AC  : POST /api/v1/attendances/batch\n{ classroom_id, date, subject_id?, records: [{student_id, status}…] }

AC  -> AC  : SchoolYearContext::assertDateNotInArchivedYear(date)

loop Pour chaque élève
  AC  -> DB  : Attendance WHERE student_id + date + subject_id
  DB  --> AC : Enregistrement existant | null
  AC  -> DB  : UPSERT Attendance { status, created_by }
  note right
    Si status ≠ absent :
    justified, justification remis à null
  end note

  alt Élève marqué absent
    AC  -> AAS : check(student)
    AAS -> DB  : Attendance WHERE student_id + status=absent\n(30 derniers jours + consécutifs)
    DB  --> AAS : Données d'absences

    alt Seuil d'alerte atteint
      AAS --> AC  : { triggered: true, reasons, consecutive, count_recent_30d }
      AC  -> AC   : alertedStudents.push(student)
    else Sous le seuil
      AAS --> AC  : { triggered: false }
    end
  end
end

loop Pour chaque élève alerté
  AC  -> ATM : notifyParentsIfNeeded(student, alertRow)
  ATM -> DB  : AttendanceAlertNotificationLog\n(vérifie doublon récent)
  alt Notification non déjà envoyée
    ATM -> PAR : Email / Notification au(x) parent(s)
    ATM -> DB  : INSERT notification_log
  end
end

AC  --> FE : 200 { message: "Présences enregistrées", alerts: […] }
FE  --> ENS : Confirmation + liste des élèves en alerte (si applicable)

== Justification d'une absence (Admin) ==

ADM -> FE  : Ouvre le dossier absence d'un élève
ADM -> FE  : Saisit la justification et valide
FE  -> AC  : PATCH /api/v1/attendances/{id}/justify\n{ justified: true, justification: "certificat médical" }

AC  -> DB  : AdminScopeContext::assertClassroomAllowed(user, attendance.classroom_id)
AC  -> AC  : SchoolYearContext::assertDateNotInArchivedYear()
AC  -> DB  : attendance->update({ justified, justification, justified_by, justified_at })
DB  --> AC : OK
AC  --> FE : 200 AttendanceResource (mise à jour)
FE  --> ADM : Absence justifiée

@enduml
