@startuml diagramme_classes_jeff_tfc
title Diagramme de classes — EduConnect

skinparam classAttributeIconSize 0
skinparam classFontStyle Bold
skinparam class {
  BackgroundColor #FAFAFA
  BorderColor #555555
  ArrowColor #444444
  HeaderBackgroundColor #D6EAF8
}
skinparam linetype ortho

' ─────────────────────────────────────────────
'  AUTHENTIFICATION / PROFILS
' ─────────────────────────────────────────────
class Utilisateur {
  +int          id_utilisateur
  +String       identifiant
  +String       email
  +String       mot_de_passe
  +Enum         role
  +Boolean      est_actif
  --
  +authentifier()
}

class Eleve {
  +int          id_eleve
  +String       matricule
  +String       prenom
  +String       nom
  +String       postnom
  +Date         date_naissance
  +String       sexe
  +Enum         statut_inscription
}

class Enseignant {
  +int          id_enseignant
  +String       numero_matricule
  +Enum         type_enseignant
  +String       specialite
  +String       genre
}

class Parent {
  +int          id_parent
  +String       telephone
  +String       adresse
}

' ─────────────────────────────────────────────
'  STRUCTURE SCOLAIRE
' ─────────────────────────────────────────────
class AnneeScolaire {
  +int          id_annee
  +String       libelle
  +Date         date_debut
  +Date         date_fin
  +Boolean      est_courante
}

class Niveau {
  +int          id_niveau
  +String       nom
  +String       abreviation
  +Enum         cycle
  +int          ordre
  +Boolean      a_options
}

class Option {
  +int          id_option
  +String       nom
  +String       filiere
}

class ClasseAnnuelle {
  +int          id_classe_annuelle
  +String       nom
  +Boolean      est_active
}

class Division {
  +int          id_division
  +String       section
  +Boolean      est_active
}

class Matiere {
  +int          id_matiere
  +String       nom
  +String       code
  +float        coefficient_defaut
}

' ─────────────────────────────────────────────
'  CALENDRIER ACADÉMIQUE
' ─────────────────────────────────────────────
class Terme {
  +int          id_terme
  +String       nom
  +int          position
  +Enum         type_terme
  +Enum         cycle_applicable
}

class Periode {
  +int          id_periode
  +String       nom
  +int          position
  +Date         date_debut
  +Date         date_fin
}

' ─────────────────────────────────────────────
'  ENSEIGNEMENT & ÉVALUATION
' ─────────────────────────────────────────────
class Affectation {
  +int          id_affectation
  +float        heures_hebdo
  +Boolean      est_principal
}

class Evaluation {
  +int          id_evaluation
  +String       nom
  +Enum         type
  +Date         date
  +float        valeur_max
  +Boolean      est_publiee
  --
  +calculerComposante()
}

class Note {
  +int          id_note
  +float        valeur
  +Boolean      est_absent
}

' ─────────────────────────────────────────────
'  SUIVI & BULLETIN
' ─────────────────────────────────────────────
class Absence {
  +int          id_absence
  +Date         date
  +Enum         statut
  +Boolean      justifiee
  +String       justification
}

class AppreciationBulletin {
  +int          id_appreciation
  +String       contenu
}

' ─────────────────────────────────────────────
'  RELATIONS
' ─────────────────────────────────────────────

' Profils utilisateurs
Utilisateur "1"   --  "0..1" Eleve
Utilisateur "1"   --  "0..1" Enseignant
Utilisateur "1"   --  "0..1" Parent
Parent      "*"   --  "*"    Eleve     : ParentEleve

' Structure scolaire
AnneeScolaire "1" --  "*"    ClasseAnnuelle
Niveau        "1" --  "*"    ClasseAnnuelle
Option      "0..1"--  "*"    ClasseAnnuelle
ClasseAnnuelle"1" --  "*"    Division
Niveau      "0..1"--  "*"    Division
Division    "*"   --  "*"    Matiere   : Programme
Eleve       "*"   --  "1"    Division

' Calendrier
AnneeScolaire "1" --  "*"    Terme
Terme         "1" --  "*"    Periode

' Enseignement
Enseignant    "1" --  "*"    Affectation
Division      "1" --  "*"    Affectation
Matiere     "0..1"--  "*"    Affectation

' Évaluation
Division      "1" --  "*"    Evaluation
Matiere       "1" --  "*"    Evaluation
Periode       "1" --  "*"    Evaluation
Evaluation    "1" --  "*"    Note
Eleve         "1" --  "*"    Note

' Suivi
Eleve         "1" --  "*"    Absence
Division      "1" --  "*"    Absence
Matiere     "0..1"--  "*"    Absence

' Bulletin
Eleve         "1" --  "*"    AppreciationBulletin
Terme         "1" --  "*"    AppreciationBulletin

@enduml
