# =============================================================================
#  EduConnect — backend/.env de PRODUCTION (exemple)
#  Copier vers backend/.env sur le serveur, puis :
#    php artisan key:generate
#  ⚠️ Génère de NOUVEAUX secrets Reverb (ne garde pas ceux de dev).
# =============================================================================
APP_NAME=EduConnect
APP_ENV=production
APP_KEY=                       # rempli par `php artisan key:generate`
APP_DEBUG=false
APP_URL=https://educonnect.school

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# --- Base de données PostgreSQL (créée sur le VPS) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=educonnect
DB_USERNAME=educonnect
DB_PASSWORD=change_me_strong

# --- Sessions / cache / queue ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Web Push (notifications navigateur) ---
# Générer une paire unique sur le serveur :
#   php artisan tinker --execute='print_r(Minishlink\WebPush\VAPID::createVapidKeys());'
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@educonnect.school

# --- Broadcast (temps réel) ---
BROADCAST_CONNECTION=reverb

# Identifiants Reverb — REMPLACER par des valeurs aléatoires uniques !
REVERB_APP_ID=educonnect-prod
REVERB_APP_KEY=change_me_public_key
REVERB_APP_SECRET=change_me_secret

# Connexion serveur->Reverb (interne, localhost)
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
# Où Reverb écoute (démon systemd)
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080

# --- Mail (à configurer selon ton fournisseur SMTP) ---
MAIL_MAILER=smtp
MAIL_HOST=smtp.exemple.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@educonnect.school
MAIL_FROM_NAME="EduConnect"
