# =============================================================================
#  EduConnect — frontend/.env.production (exemple)
#  Copier vers frontend/.env.production AVANT `npm run build`.
#  Vite charge automatiquement ce fichier en mode production.
#
#  L'API est appelée en chemins relatifs (/api...) -> même origine, rien à régler.
#  Ici on ne configure QUE le WebSocket public (Reverb via wss derrière Nginx).
# =============================================================================

# Doit être IDENTIQUE à REVERB_APP_KEY du backend (clé publique, envoyée au client)
VITE_REVERB_APP_KEY=change_me_public_key

# Hôte/port/scheme PUBLICS : le client se connecte en wss://domaine:443/app/...
VITE_REVERB_HOST=educonnect.school
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
